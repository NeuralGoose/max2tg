# Скопируйте в .env и заполните. НЕ коммитьте .env (там токены).
MAX2TG_TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token
# Private chat with the bot (send /start first). QR/SMS/2FA prompts and /commands.
MAX2TG_TELEGRAM_CHAT_ID=2097379459
# REQUIRED for normal use: Telegram supergroup with Topics enabled. One forum topic
# per MAX chat. Bot must be admin with Manage Topics.
MAX2TG_TELEGRAM_TOPICS_ENABLED=true
MAX2TG_TELEGRAM_FORUM_CHAT_ID=-1001234567890
# Emergency dump when topic creation fails (defaults to TELEGRAM_CHAT_ID). Not a
# substitute for topics — messages land in one interleaved stream; Reply only.
MAX2TG_TELEGRAM_FALLBACK_CHAT_ID=2097379459
MAX2TG_TELEGRAM_PRELOAD_TOPICS=true
MAX2TG_TELEGRAM_SEED_LAST_MESSAGES=true
# Max chats to process after discovery (not login batch size or message depth).
MAX2TG_TELEGRAM_PRELOAD_CHAT_COUNT=100
# Chat discovery: login = client.chats from sync only; fetch = paginated fetch_chats.
MAX2TG_TELEGRAM_PRELOAD_CHAT_SOURCE=login
# Recent messages per chat to mirror on preload (0 = topics only; 1 = last message).
# Raising depth on already-seeded topics may require deleting the Telegram topic
# or clearing that chat's entry in state.json so history re-seeds in order.
MAX2TG_TELEGRAM_PRELOAD_MESSAGE_DEPTH=1
# Safety cap on fetch_chats pagination when PRELOAD_CHAT_SOURCE=fetch.
MAX2TG_TELEGRAM_PRELOAD_FETCH_PAGES=20
# Pause between chats during preload (seconds).
MAX2TG_TELEGRAM_PRELOAD_CHAT_DELAY_SECONDS=0.35
# Minimum spacing between Telegram Bot API calls (seconds).
MAX2TG_TELEGRAM_API_MIN_INTERVAL_SECONDS=0.05
# Stricter pacing during topic preload / seeding (seconds).
MAX2TG_TELEGRAM_PRELOAD_API_MIN_INTERVAL_SECONDS=1.0
# MAX chat ids to never mirror (comma-separated). Default 0 = Saved Messages / Избранное.
MAX2TG_TELEGRAM_EXCLUDE_CHAT_IDS=0
# Forum topic badges use Telegram preset colors + sticker emoji (not MAX photo avatars).
# Set to false to stop the "✅ Отправлено в MAX" confirmation after each reply
# (keeps topics clean; errors are still reported). Works even when tokens come
# from config.json.
MAX2TG_TELEGRAM_CONFIRM_SENT=true
# Optional: where to store the chat->topic map. In Docker it is kept on a
# named volume (see docker-compose.yml) so topics survive restarts/rebuilds.
# MAX2TG_STATE_PATH=/data/state.json
# Bidirectional MAX↔Telegram message links (replies, reactions, edits). Defaults
# to links.db next to state.json.
# MAX2TG_LINKS_DB_PATH=/data/links.db
#
# --- MAX login -------------------------------------------------------------
# How to log in to MAX: token (default), sms, or qr.
#   token = paste a web session token (below); fully non-interactive
#   sms   = log in by phone + SMS code (prompted via the Telegram chat above)
#   qr    = scan a QR shown in the Telegram chat above
# MAX2TG_AUTH_METHOD=token
# Phone in international format, REQUIRED only for MAX2TG_AUTH_METHOD=sms.
# MAX2TG_MAX_PHONE=+79990000000
# Where PyMax persists its SQLite session so a restart doesn't force re-login.
# Defaults to /data (a mounted volume in Docker). Set a writable local path for
# bare `python main.py` runs outside Docker.
# MAX2TG_WORK_DIR=/data
# MAX2TG_SESSION_DB=max.db
# Токен из web.max.ru (F12 -> Console), REQUIRED only for AUTH_METHOD=token:
#   copy(JSON.parse(localStorage.__oneme_auth).token)
MAX2TG_MAX_TOKEN=paste-your-max-session-token-here
